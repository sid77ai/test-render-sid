# =============================================================================
# Hermes Agent — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
#
# After deploying to Render, you can also set these via:
#   - Render Dashboard → Environment tab
#   - Hermes web dashboard → API Keys tab
# =============================================================================

# --- LLM Provider (REQUIRED) ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Telegram (OPTIONAL) ---
# Get a bot token from @BotFather on Telegram
# Get your user ID from @userinfobot
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_ALLOW_FROM=YOUR_TELEGRAM_USER_ID

# --- Web Search (OPTIONAL) ---
# DuckDuckGo is built-in and free (no key needed).
# For enhanced search, add one of:
# TAVILY_API_KEY=tvly-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# FIRECRAWL_API_KEY=fc-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# EXA_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Browser Automation (OPTIONAL) ---
# BROWSERBASE_API_KEY=bbp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Image Generation (OPTIONAL) ---
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- OpenAI-Compatible API Server (OPTIONAL) ---
# Enable to expose Hermes as an OpenAI-compatible endpoint
# API_SERVER_ENABLED=true
# API_SERVER_KEY=your-api-server-key
